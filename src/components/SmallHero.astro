---
import { Image } from "astro:assets";

const {
  title,
  subtitle,
  description,
  ctaText,
  ctaLink,
  image,
  className = ""
} = Astro.props;
---

<section class={`small-hero ${className}`}>
  <Image
  src={image}
  alt={title || ""}
  class="small-hero-bg"
  width={1400}
  priority
/>

  <div class="small-hero-overlay"></div>

  <div class="small-hero-content">
    <div class="small-hero-text">
      <h1>{title}</h1>
      <p class="small-subtitle">{subtitle}</p>
    </div>
  </div>
</section>