---
import { Image } from "astro:assets";

interface Props {
  image: any;
  title: string;
  excerpt: string;
  slug: string;
  lang: string; 
  readMore: string;
}

const { image, title, excerpt, slug, lang, readMore } = Astro.props;
---

<section class="featured-post">
  <div class="featured-container">
    <div class="featured-inner">

      <div class="featured-image">
        <Image
          src={image}
          alt={title}
          width={1200}
          sizes="(max-width: 900px) 100vw, 50vw"
          priority
        />
      </div>

      <div class="featured-content">
        <h2>
          <a href={`/${lang}/blog/${slug}`}>{title}</a>
                </h2>

        <p>{excerpt}</p>

        <a href={`/${lang}/blog/${slug}`} class="read-more">          
          {readMore}      </a>
      </div>

    </div>
  </div>
</section>