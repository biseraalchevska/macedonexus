---
import { Image } from "astro:assets";

interface Props {
  image: any;
  title: string;
  excerpt: string;
  slug: string;
  lang: string;
  readMore: string;
}

const {
  image,
  title,
  excerpt,
  slug,
  lang,
  readMore
} = Astro.props as Props;
---

<a href={`/${lang}/blog/${slug}`} class="blog-card">
  <Image
    src={image}
    alt={title}
    width={600}
    sizes="(max-width: 768px) 100vw, 33vw"
  />

  <div class="blog-card-content">
    <h3>{title}</h3>
    <p>{excerpt}</p>
    <span class="read-more">{readMore} →</span>
  </div>
</a>