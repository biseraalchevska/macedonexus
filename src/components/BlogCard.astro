---
import { Image } from "astro:assets";

interface Props {
  image: any;
  title: string;
  excerpt: string;
  slug: string;
}

const { image, title, excerpt, slug } = Astro.props;
---

<a href={`/blog/${slug}`} class="blog-card">
  <Image
    src={image}
    alt={title}
    width={600}
    sizes="(max-width: 768px) 100vw, 33vw"
  />

  <div class="blog-card-content">
    <h3>{title}</h3>
    <p>{excerpt}</p>
    <span class="read-more">Read More →</span>
  </div>
</a>