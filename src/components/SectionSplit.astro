---
import { Image } from "astro:assets";

const { title, text, image, className = "" } = Astro.props;
---

<section class={`section-split ${className}`}>
  <div class="split-text">
    <h2>{title}</h2>
    <p>{text}</p>
  </div>

  <div class="split-image">
    <Image
      src={image}
      alt={title}
      width={700}
      loading="lazy"
    />
  </div>
</section>
