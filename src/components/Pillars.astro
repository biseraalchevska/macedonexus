---
const { t } = Astro.props;
---

<section class="pillars">
  <div class="pillars-inner">

    <div class="pillars-header">
      <span class="pillars-label">{t.home.pillars.title}</span>
      <div class="pillars-divider"></div>
    </div>

    <div class="pillar-grid">
      {t.home.pillars.items.map((pillar:any) => (
        <div class="pillar">
          <h3>{pillar.title}</h3>
          <p>{pillar.text}</p>
        </div>
      ))}
    </div>

  </div>
</section>
