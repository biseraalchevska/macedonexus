---
import BaseLayout from "../layouts/BaseLayout.astro";
import SmallHero from "../components/SmallHero.astro";
import SectionSplit from "../components/SectionSplit.astro";
import TeamMember from "../components/TeamMember.astro";
import aboutHero from "../assets/about.png";
import splitImage from "../assets/split.jpg";

import artifactIcon from "../assets/artifact.png";
import compassIcon from "../assets/compass.png";
import bookIcon from "../assets/book.png";
import ancestryIcon from "../assets/ancestry.png";


---

<BaseLayout title="About Us">
<div class="about-top">
<SmallHero
image={aboutHero}
/>
<SectionSplit
  title="About Macedonexus"
  text="Macedonexus was created as a bridge between cultures long connected through
  movement, exchange and shared histories. It brings together language, memory and
  place to offer thoughtful, human-centered support for individuals, families, and
  communities living across borders."
  image={splitImage}
/>
</div>

<section class="team-section">
  <h1 class="team-title">Our Team</h1>

  <div class="team-grid">
    <TeamMember
      name="Natali"
      title="Cultural Interpreter"
      bio="Cultural interpreter with a background in archaeological materials science. Natali
      focuses on cultural interpretation, identity, heritage and cross-cultural understanding,
      shaping the vision and intellectual direction of Macedonexus."
      icon={artifactIcon}
    />

    <TeamMember
      name="Zharko"
      title="Translator & Guide"
      bio="Certified Macedonian–Turkish translator and licensed tour guide. He offers
      professional translation services, guided cultural experiences in Macedonia, support
      in navigating medical care in Turkey, assistance with administrative procedures
      related to Macedonian citizenship applications, as well as investment and
      institutional support, including local orientation and facilitation of communication with
      relevant institutions and trusted local partners."
      icon={compassIcon}
    />

    <TeamMember
      name="Melani"
      title="Translator & Language Lecturer"
      bio="Certified Macedonian-Turkish translator. She offers language lessons for Turkish and
      Macedonian learners, with a strong emphasis on practical communication and
      cultural context."
      icon={bookIcon}
    />

    <TeamMember
      name="Sofija"
      title="Ancestry Research Support"
      bio="She supports individuals and families in exploring their ancestry through family
      records, oral history and cultural context, with a particular focus on diaspora
      connections and intergenerational memory."
      icon={ancestryIcon}
    />
  </div>
</section>



</BaseLayout>


